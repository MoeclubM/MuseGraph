{
  "name": "musegraph",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:web": "pnpm --filter @musegraph/web test",
    "test:web:coverage": "pnpm --filter @musegraph/web test:coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && node -e \"require('node:fs').rmSync('node_modules', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "turbo": "^2.10.5"
  },
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24.0.0"
  }
}
