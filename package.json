{
  "name": "musegraph",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm --dir apps/web-vue build",
    "test": "pnpm --dir apps/web-vue test",
    "test:web": "pnpm --filter @musegraph/web test",
    "typecheck": "pnpm --dir apps/web-vue exec vue-tsc -b",
    "clean": "turbo run clean && node -e \"require('node:fs').rmSync('node_modules', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "turbo": "^2.10.5"
  },
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
