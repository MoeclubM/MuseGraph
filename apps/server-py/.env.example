# Database
DATABASE_URL=postgresql+asyncpg://musegraph:musegraph123@localhost:5432/musegraph

# Redis
REDIS_URL=redis://localhost:6379

# Session
SESSION_EXPIRES_HOURS=168

# AI providers, API keys, and model lists are configured in Admin -> Providers

# Hy-Memory
MEMORY_MODE=ultra
MEMORY_DATA_DIR=.musegraph/memory
MEMORY_VECTOR_STORE=chroma
MEMORY_COLLECTION_NAME=musegraph_memories
MEMORY_GRAPH_PROVIDER=kuzu
MEMORY_CACHE_BACKEND=sqlite
MEMORY_EMBEDDING_DIMS=1024
MEMORY_INGEST_CHUNK_SIZE=4000
MEMORY_SEARCH_MIN_SCORE=0.35
MEMORY_PROFILE_SEARCH_MIN_SCORE=0.35
MEMORY_INTENTION_LIMIT=4

# Agent
AGENT_FLOW_TIMEOUT_SECONDS=1800
AGENT_PI_TOOL_LOOP_ENABLED=true
AGENT_PI_TOOL_LOOP_MAX_ITERATIONS=8
AGENT_PI_TOOL_LOOP_MAX_TOKENS=2048

# App
APP_URL=http://localhost:3010
AUTO_SEED_DATA=false

TELEMETRY_DISABLED=true
# Optional seed admin (used only when running seed.py)
SEED_ADMIN_EMAIL=
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NICKNAME=Administrator
