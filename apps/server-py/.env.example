# Database
DATABASE_URL=postgresql+asyncpg://musegraph:musegraph123@localhost:5432/musegraph

# Redis
REDIS_URL=redis://localhost:6379

# Session
SESSION_EXPIRES_HOURS=168

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET=musegraph

# AI providers, API keys, and model lists are configured in Admin -> Providers

# Local Graphiti / optional legacy Cognee Neo4j
NEO4J_URL=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
GRAPHITI_DB_PATH=.musegraph/graphiti/graphiti.kuzu
GRAPHITI_EMBEDDING_DIM=1024

# App
APP_URL=http://localhost:3000
AUTO_SEED_DATA=false

TELEMETRY_DISABLED=true
# Optional seed admin (used only when running seed.py)
SEED_ADMIN_EMAIL=
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NICKNAME=Administrator

GRAPH_BACKEND=graphiti
